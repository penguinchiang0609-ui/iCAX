<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="ICAXCopyOpenCascadeRuntime" AfterTargets="Build" Condition="Exists('$(ICAXOpenCascadeBinDir)')">
    <ItemGroup>
      <_ICAXOpenCascadeRuntimeDll Include="$(ICAXOpenCascadeBinDir)*.dll" />
    </ItemGroup>
    <Copy
      SourceFiles="@(_ICAXOpenCascadeRuntimeDll)"
      DestinationFolder="$(OutDir)"
      SkipUnchangedFiles="true"
      Condition="'@(_ICAXOpenCascadeRuntimeDll)' != ''" />
  </Target>
</Project>
