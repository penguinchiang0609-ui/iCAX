{
  "schema": "icax.product.manifest",
  "schemaVersion": 1,
  "productId": "icax.laser-3d-cam",
  "productName": "三维线条切割 CAM",
  "productVersion": "0.1.0",
  "projectFile": {
    "magic": "ICAX_LASER_3D_CAM",
    "formatVersion": "0.1",
    "quickSaveLogMagic": "ICAX_LASER_3D_CAM_QSAVE",
    "quickSaveLogVersion": 1,
    "fileExtensions": [".i3cam"],
    "magicOffset": 0,
    "probeBytes": 256
  },
  "backend": {
    "startupComponent": "CLaserCamRootComponent",
    "pdo": {
      "enabled": true,
      "arenaSize": 134217728,
      "slotCapacity": 4096
    },
    "modules": {
      "dependencies": [
        "../../iCAX-Plugins/render/RenderData/${Platform}/${Configuration}/RenderData.dll",
        "../../iCAX-Plugins/render/RenderService/${Platform}/${Configuration}/RenderService.dll",
        "../../iCAX-Plugins/render/RenderPDO/${Platform}/${Configuration}/RenderPDO.dll",
        "../../iCAX-Plugins/render/PDORenderService/${Platform}/${Configuration}/PDORenderService.dll"
      ],
      "components": ["../../iCAX-Plugins/cam/Laser3DCAM/${Platform}/${Configuration}/Laser3DCAM.dll"],
      "behaviours": ["../../iCAX-Plugins/cam/Laser3DCAM/${Platform}/${Configuration}/Laser3DCAM.dll"],
      "services": [
        "../../iCAX-Plugins/render/PDORenderService/${Platform}/${Configuration}/PDORenderService.dll",
        "../../iCAX-Plugins/cam/Laser3DCAM/${Platform}/${Configuration}/Laser3DCAM.dll"
      ],
      "commands": ["../../iCAX-Plugins/cam/Laser3DCAM/${Platform}/${Configuration}/Laser3DCAM.dll"]
    },
    "resources": {
      "handlers": [
        {
          "kind": "importer",
          "resourceType": "geometry.brep",
          "formatId": "cad.step",
          "extensions": [".step", ".stp"],
          "module": "../../iCAX-Plugins/cad/OpenCascadeResourceImport/${Platform}/${Configuration}/OpenCascadeResourceImport.dll",
          "provider": "occ.opencascade",
          "priority": 100
        },
        {
          "kind": "importer",
          "resourceType": "geometry.brep",
          "formatId": "cad.iges",
          "extensions": [".igs", ".iges"],
          "module": "../../iCAX-Plugins/cad/OpenCascadeResourceImport/${Platform}/${Configuration}/OpenCascadeResourceImport.dll",
          "provider": "occ.opencascade",
          "priority": 100
        }
      ]
    }
  },
  "webpage": {
    "entry": "apps/laser-3d-cam/webpage/entry.mjs"
  }
}
