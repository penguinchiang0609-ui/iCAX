{
  "schema": "icax.product.manifest",
  "schemaVersion": 1,
  "productId": "icax.laser-3d-cam",
  "productName": "三维线条切割 CAM",
  "productVersion": "0.1.0",
  "capabilities": {
    "machineDefinition": {
      "supportedFormats": [
        {
          "formatId": "machine.sdf",
          "name": "SDF 机床定义",
          "extensions": [".sdf", ".xml"]
        },
        {
          "formatId": "machine.urdf",
          "name": "URDF 机床定义",
          "extensions": [".urdf"]
        }
      ]
    }
  },
  "projectFile": {
    "magic": "ICAX_LASER_3D_CAM",
    "formatVersion": "0.1",
    "quickSaveLogMagic": "ICAX_LASER_3D_CAM_QSAVE",
    "quickSaveLogVersion": 1,
    "fileExtensions": [".i3cam"],
    "magicOffset": 0,
    "probeBytes": 256
  },
  "backend": {
    "startupComponent": "CSceneBootstrapComponent",
    "pdo": {
      "enabled": true,
      "arenaSize": 134217728,
      "slotCapacity": 4096
    },
    "modules": {
      "dependencies": [
        "../../${Platform}/${Configuration}/RenderData.dll",
        "../../${Platform}/${Configuration}/RenderService.dll",
        "../../${Platform}/${Configuration}/RenderPDO.dll",
        "../../${Platform}/${Configuration}/PDORenderService.dll",
        "../../${Platform}/${Configuration}/InputPDO.dll",
        "../../${Platform}/${Configuration}/InputService.dll",
        "../../${Platform}/${Configuration}/Transform.dll",
        "../../${Platform}/${Configuration}/ColliderData.dll",
        "../../${Platform}/${Configuration}/RenderInteraction.dll",
        "../../${Platform}/${Configuration}/CameraNavigation.dll"
      ],
      "components": [
        "../../${Platform}/${Configuration}/Transform.dll",
        "../../${Platform}/${Configuration}/RenderInteraction.dll",
        "../../${Platform}/${Configuration}/CameraNavigation.dll",
        "../../${Platform}/${Configuration}/Laser3DCAM.dll"
      ],
      "behaviours": [
        "../../${Platform}/${Configuration}/RenderInteraction.dll",
        "../../${Platform}/${Configuration}/CameraNavigation.dll",
        "../../${Platform}/${Configuration}/Laser3DCAM.dll"
      ],
      "services": [
        "../../${Platform}/${Configuration}/InputService.dll",
        "../../${Platform}/${Configuration}/PDORenderService.dll",
        "../../${Platform}/${Configuration}/Laser3DCAM.dll"
      ],
      "facades": ["../../${Platform}/${Configuration}/Laser3DCAM.dll"]
    },
    "resources": {
      "handlers": [
        {
          "kind": "importer",
          "resourceType": "geometry.brep",
          "formatId": "cad.step",
          "extensions": [".step", ".stp"],
          "module": "../../${Platform}/${Configuration}/OpenCascadeResourceImport.dll",
          "provider": "occ.opencascade",
          "priority": 100
        },
        {
          "kind": "importer",
          "resourceType": "geometry.brep",
          "formatId": "cad.iges",
          "extensions": [".igs", ".iges"],
          "module": "../../${Platform}/${Configuration}/OpenCascadeResourceImport.dll",
          "provider": "occ.opencascade",
          "priority": 100
        },
        {
          "kind": "importer",
          "resourceType": "geometry.triangle_mesh",
          "formatId": "geometry.stl",
          "extensions": [".stl"],
          "module": "../../${Platform}/${Configuration}/STLResourceImport.dll",
          "provider": "icax.stl",
          "priority": 100
        },
        {
          "kind": "importer",
          "resourceType": "geometry.triangle_mesh",
          "formatId": "geometry.dae",
          "extensions": [".dae"],
          "module": "../../${Platform}/${Configuration}/DAEResourceImport.dll",
          "provider": "icax.dae",
          "priority": 100
        }
      ]
    }
  },
  "webpage": {
    "entry": "apps/laser-3d-cam/webpage/entry.mjs"
  }
}
